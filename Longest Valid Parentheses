class Solution:
    def longestValidParentheses(self, s: str) -> int:
        left = right = maxlength = 0
        
        # Left-to-right pass
        for char in s:
            if char == '(':
                left += 1
            else:
                right += 1
            
            if left == right:
                maxlength = max(maxlength, 2 * right)
            elif right > left:
                left = right = 0
        
        left = right = 0
        # Right-to-left pass (to catch cases like "((()")
        for char in reversed(s):
            if char == '(':
                left += 1
            else:
                right += 1
            
            if left == right:
                maxlength = max(maxlength, 2 * left)
            elif left > right:
                left = right = 0
                
        return maxlength
