class Solution:
    def firstMissingPositive(self, nums: List[int]) -> int:
        n = len(nums)
        
        for i in range(n):
            # While the current number is in the valid range [1, n]
            # and it is not in its correct position (nums[i] - 1)
            # and the target position doesn't already have the correct value (to avoid infinite loops)
            while 1 <= nums[i] <= n and nums[nums[i] - 1] != nums[i]:
                # Swap nums[i] to its correct target index
                target = nums[i] - 1
                nums[i], nums[target] = nums[target], nums[i]
        
        # After sorting, the first index 'i' where nums[i] != i + 1
        # tells us that 'i + 1' is the missing positive.
        for i in range(n):
            if nums[i] != i + 1:
                return i + 1
                
        # If all numbers 1 to n are present, the missing one is n + 1
        return n + 1
