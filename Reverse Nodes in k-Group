class Solution:
    def reverseKGroup(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:
        # 1. Check if there are k nodes to reverse
        curr = head
        for _ in range(k):
            if not curr:
                return head # Not enough nodes, return as is
            curr = curr.next
        
        # 2. Reverse k nodes
        prev = None
        curr = head
        for _ in range(k):
            nxt = curr.next
            curr.next = prev
            prev = curr
            curr = nxt
        
        # 3. Recursively call for the next group and connect
        # head is now the end of the reversed section
        head.next = self.reverseKGroup(curr, k)
        
        # prev is now the new head of the reversed section
        return prev
