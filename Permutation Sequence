import math

class Solution:
    def getPermutation(self, n: int, k: int) -> str:
        # Create a list of numbers to pick from: [1, 2, 3, ..., n]
        nums = [str(i) for i in range(1, n + 1)]
        
        # Adjust k to be 0-indexed for easier calculation
        k -= 1
        
        res = []
        # Calculate factorials or use math.factorial
        # The number of permutations starting with a specific digit is (n-1)!
        for i in range(n, 0, -1):
            # Block size for the current position
            factorial = math.factorial(i - 1)
            
            # Index of the number we want in the current nums list
            idx = k // factorial
            
            # Append the selected number to result and remove from available list
            res.append(nums.pop(idx))
            
            # Update k for the remaining positions
            k %= factorial
            
        return "".join(res)
