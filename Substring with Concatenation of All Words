from collections import Counter

class Solution:
    def findSubstring(self, s: str, words: List[str]) -> List[int]:
        if not s or not words:
            return []
        
        word_len = len(words[0])
        word_count = len(words)
        total_len = word_len * word_count
        word_freq = Counter(words)
        result = []
        
        # We only need to shift the starting point by word_len to cover all offsets
        for i in range(word_len):
            left = i
            right = i
            current_count = Counter()
            
            while right + word_len <= len(s):
                # Extract the word from the right side of the window
                word = s[right:right + word_len]
                right += word_len
                
                if word in word_freq:
                    current_count[word] += 1
                    
                    # If we have more occurrences of 'word' than needed, shrink from left
                    while current_count[word] > word_freq[word]:
                        left_word = s[left:left + word_len]
                        current_count[left_word] -= 1
                        left += word_len
                    
                    # If window size matches total_len, we found a valid starting index
                    if right - left == total_len:
                        result.append(left)
                else:
                    # Invalid word found, reset the window
                    current_count.clear()
                    left = right
                    
        return result
