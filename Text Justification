class Solution:
    def fullJustify(self, words: List[str], maxWidth: int) -> List[str]:
        res, cur, num_of_letters = [], [], 0
        
        for w in words:
            # Check if adding the next word exceeds maxWidth
            # len(cur) accounts for the minimum 1 space between words
            if num_of_letters + len(w) + len(cur) > maxWidth:
                # Distribute spaces for the completed line
                for i in range(maxWidth - num_of_letters):
                    # Use modulo to cycle through gaps between words
                    # If only 1 word, len(cur)-1 is 0; handle that separately
                    cur[i % (len(cur) - 1 or 1)] += ' '
                res.append("".join(cur))
                cur, num_of_letters = [], 0
            
            cur.append(w)
            num_of_letters += len(w)
            
        # Handle the last line (left-justified)
        last_line = " ".join(cur)
        res.append(last_line + ' ' * (maxWidth - len(last_line)))
        
        return res
